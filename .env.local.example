# ============================================================
# AO PLATFORM — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# --- SUPABASE (obligatoire) ---
# Trouvez ces valeurs dans : Settings > API de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_ici
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_ici  # Ne jamais exposer côté client

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # En prod : https://votre-domaine.com

# --- ANTHROPIC (pour les modules IA) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- STRIPE (pour les paiements — à ajouter plus tard) ---
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
